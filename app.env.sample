# Shopware - E-commerce platform
# Copy to app.env and customize before starting

# Timezone
TZ=America/New_York

# Hostname / Domain
BASE_HOST_NAME=${HOSTNAME}
BASE_DOMAIN_NAME=example.com

# Database credentials
DB_CREATE_DATABASE_NAME=shopware
DB_USER_NAME=shopware
DB_USER_PASS=changeme_db_password
DB_ADMIN_PASS=changeme_admin_password

# Application secret key (must be at least 32 characters)
APP_SECRET_KEY=changeme_secret_key_min_32_chars

# Email configuration
EMAIL_SERVER_HOST=localhost
EMAIL_SERVER_PORT=25
